# --- React / Node ---
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Python Backend ---
# Excludes the virtual environment regardless of what you named it
backend/venv/
backend/.venv/
venv/
.venv/

# Excludes compiled Python files
**/__pycache__/
*.py[cod]
*$py.class

# --- Database ---
# Keeps your database on your machine, not on the web
backend/*.db
backend/*.sqlite3
*.db

# --- Environment & Secrets ---
# VERY IMPORTANT: This keeps your SECRET_KEY safe
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Editor / OS Files ---
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?